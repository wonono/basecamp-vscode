{
  "name": "basecamp-vscode",
  "displayName": "Basecamp for VSCode",
  "description": "Basecamp projects, campfire chat, to-dos, and messages inside VSCode",
  "version": "0.1.0",
  "publisher": "Wonono",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "files": [
    "dist",
    "resources",
    "webview"
  ],
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/basecamp-vscode/basecamp-vscode"
  },
  "contributes": {
    "viewContainers": {
      "activitybar": [
        {
          "id": "basecamp-sidebar",
          "title": "Basecamp",
          "icon": "resources/basecamp-icon.svg"
        }
      ]
    },
    "views": {
      "basecamp-sidebar": [
        {
          "id": "basecamp-projects",
          "name": "Projects",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "basecamp.signIn",
        "title": "Sign In",
        "category": "Basecamp"
      },
      {
        "command": "basecamp.signOut",
        "title": "Sign Out",
        "category": "Basecamp"
      },
      {
        "command": "basecamp.refresh",
        "title": "Refresh",
        "category": "Basecamp",
        "icon": "$(refresh)"
      },
      {
        "command": "basecamp.openCampfire",
        "title": "Open Campfire",
        "category": "Basecamp"
      },
      {
        "command": "basecamp.openMessage",
        "title": "Open Message",
        "category": "Basecamp"
      },
      {
        "command": "basecamp.openTodoList",
        "title": "Open To-do List",
        "category": "Basecamp"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "basecamp.refresh",
          "when": "view == basecamp-projects",
          "group": "navigation"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "basecamp-projects",
        "contents": "Connect your Basecamp account to get started.\n[Sign In](command:basecamp.signIn)"
      }
    ],
    "configuration": {
      "title": "Basecamp",
      "properties": {
        "basecamp.clientId": {
          "type": "string",
          "default": "",
          "description": "OAuth Client ID from Basecamp Launchpad (https://launchpad.37signals.com/integrations)"
        },
        "basecamp.clientSecret": {
          "type": "string",
          "default": "",
          "description": "OAuth Client Secret from Basecamp Launchpad"
        },
        "basecamp.pollingInterval": {
          "type": "number",
          "default": 15,
          "minimum": 5,
          "description": "Polling interval in seconds for Campfire chat"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc --noEmit && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "tsc --noEmit && node esbuild.js --production",
    "vscode:prepublish": "npm run package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "esbuild": "^0.19.0"
  }
}
